# ──────────────────────────────────────────────────────────────────────────────
# Nexus Grid — variables d'environnement
# Copie ce fichier en ".env" et remplis les valeurs réelles.
# Ne commit JAMAIS le fichier .env dans git.
# ──────────────────────────────────────────────────────────────────────────────

# Environnement : "development" | "production"
APP_ENV=development

# Clé secrète JWT — OBLIGATOIRE en production (différente de la valeur par défaut)
# Génère-en une : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Durée des tokens
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexusgrid

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic Claude — obligatoire pour toutes les fonctions IA
ANTHROPIC_API_KEY=sk-ant-...

# Origines CORS autorisées (séparées par des virgules)
# Développement :
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production : remplace par ton vrai domaine :
# ALLOWED_ORIGINS=https://mondomaine.com
